# Grant the active local user access to Apple Studio Display hiddev nodes
# so asdcontrol can adjust brightness without root.
# asdcontrol uses the hiddev ioctl interface (/dev/usb/hiddev*, subsystem
# `usbmisc`) — not hidraw — so the match must target that subsystem.
# `seat` tag is required alongside `uaccess` so systemd-logind associates
# the device with seat0 and applies the ACL for the active session user.
KERNEL=="hiddev*", SUBSYSTEM=="usbmisc", ATTRS{idVendor}=="05ac", ATTRS{idProduct}=="1114", TAG+="uaccess", TAG+="seat"
KERNEL=="hiddev*", SUBSYSTEM=="usbmisc", ATTRS{idVendor}=="05ac", ATTRS{idProduct}=="1116", TAG+="uaccess", TAG+="seat"
KERNEL=="hiddev*", SUBSYSTEM=="usbmisc", ATTRS{idVendor}=="05ac", ATTRS{idProduct}=="1118", TAG+="uaccess", TAG+="seat"
KERNEL=="hiddev*", SUBSYSTEM=="usbmisc", ATTRS{idVendor}=="05ac", ATTRS{idProduct}=="9243", TAG+="uaccess", TAG+="seat"
