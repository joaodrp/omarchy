#!/bin/bash
# omarchy theme-set hook: pin a custom wallpaper to the Nord theme.
#
# omarchy-hook passes the normalized theme name (lowercase, dashes) as $1, and
# runs this AFTER omarchy's own bg-next, so setting the background here wins for
# Nord while leaving every other theme's default behaviour untouched.
#
# Missing-file safe: the wallpaper is a chezmoi-managed symlink into ~/Pictures.
# `[[ -f ]]` follows the symlink, so if the target image isn't present (e.g. a
# machine without that picture) this is a no-op and omarchy's default background
# stays. (omarchy theme bg set guards the same case again.)
[[ "$1" == "nord" ]] || exit 0

wallpaper="$HOME/.config/omarchy/backgrounds/nord/3-night-dunes.png"
[[ -f "$wallpaper" ]] && omarchy theme bg set "$wallpaper"
exit 0
