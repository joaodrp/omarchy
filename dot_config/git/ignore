# Global gitignore (~/.config/git/ignore — read automatically by git)

# Editor temp files (vim/nvim swap and backup)
*.swp
*.swo
*~

# Environment / local overrides
# Convention: <name>.local or <name>.local.<ext> are user-specific
# overrides not meant to be committed (e.g. .env.local,
# settings.local.json, CLAUDE.local.md).
.env
*.local
*.local.*

# Local-only project directories
_local/
