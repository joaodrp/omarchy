; Personal git overrides layered on top of ~/.config/git/config
; (omarchy's defaults). Git reads ~/.gitconfig after the XDG config,
; so values here win on conflict.

[apply]
	whitespace = fix

[core]
	pager = delta
	whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
	editor = nvim
	quotepath = false
	hooksPath = ~/.config/git/hooks

[diff]
	renames = copies

[diff "bin"]
	textconv = hexdump -v -C

[push]
	default = current

[merge]
	log = true
	conflictStyle = zdiff3

[help]
	autocorrect = prompt

[fetch]
	prune = true
	pruneTags = true

[submodule]
	recurse = true
	fetchJobs = 0

[rebase]
	autoSquash = true
	autoStash = true

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
