#!/bin/bash
# Materialize agent API keys from 1Password into a chmod-600 env file that the
# MCP-server wrapper loads at spawn. Run after rotating a key, then restart the
# agent. Exits cleanly if 1Password is locked.
set -e

OUT="$HOME/.config/agent-secrets.env"

KEYS="
CONTEXT7_API_KEY=op://Personal/Context7/api_key
PERPLEXITY_API_KEY=op://Personal/Perplexity/api_key
"

command -v op >/dev/null || { echo "refresh-agent-secrets: op not found" >&2; exit 0; }

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT
while IFS='=' read -r var ref; do
    [ -n "$var" ] || continue
    val="$(op read "$ref" 2>/dev/null)" \
        || { echo "refresh-agent-secrets: cannot read $ref (1Password locked?)" >&2; exit 1; }
    printf '%s=%s\n' "$var" "$val" >> "$tmp"
done <<< "$KEYS"

install -D -m 600 "$tmp" "$OUT"
echo "refresh-agent-secrets: wrote $OUT — restart your agent to load"
