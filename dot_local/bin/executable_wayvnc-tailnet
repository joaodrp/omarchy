#!/bin/bash
# Serve the Hyprland desktop over VNC, bound to the Tailscale IP only (ufw
# already keeps 5900 off the LAN). Waits for Tailscale to come up first, and
# caps the frame rate since the display is 5K.
set -e

for _ in $(seq 1 30); do
    ip=$(tailscale ip -4 2>/dev/null) && [ -n "$ip" ] && break
    sleep 2
done
[ -n "${ip:-}" ] || exit 0

exec wayvnc "$ip" 5900 --max-fps=30
